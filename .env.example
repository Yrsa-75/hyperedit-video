# ============================================================
# ClipWise – Environment Variables Reference
# ============================================================
# For LOCAL development: copy this to .dev.vars (already gitignored)
# For CLOUDFLARE deployment: set via `wrangler secret put KEY_NAME`
# For RAILWAY deployment: set via Railway dashboard → Variables tab
# ============================================================

# ── AI APIs ──────────────────────────────────────────────────
# Google Gemini – used by Cloudflare Worker (AI edit commands)
# and FFmpeg server (animation generation, analysis)
GEMINI_API_KEY=

# fal.ai – used by FFmpeg server for image/video generation
# (Picasso panel, DiCaprio panel)
FAL_API_KEY=
FAL_KEY=         # Set to the same value as FAL_API_KEY

# GIPHY – used by FFmpeg server for GIF search
GIPHY_API_KEY=

# OpenAI – used by FFmpeg server for additional AI features
OPENAI_API_KEY=

# ── Frontend Build (Vite) ─────────────────────────────────────
# URL of the deployed Railway FFmpeg server.
# Leave empty for local development (falls back to http://localhost:3333)
VITE_FFMPEG_SERVER_URL=https://your-project.up.railway.app

# ── FFmpeg Server (Railway) ───────────────────────────────────
# Port the FFmpeg server listens on (Railway sets this automatically)
PORT=3333

# Remotion GL renderer override (auto-detected: swiftshader on Linux, angle on macOS)
# Only set this if auto-detection doesn't work for your environment
# REMOTION_GL=--gl=swiftshader
